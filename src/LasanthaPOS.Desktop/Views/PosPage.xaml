<Page x:Class="LasanthaPOS.Desktop.Views.PosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Point of Sale" Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Point of Sale"
                   FontSize="24" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,16"/>

        <!-- Product Search -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Grid.Column="0" Height="36" FontSize="14"
                         Padding="8,6"
                         KeyUp="TxtSearch_KeyUp"/>
                <Button Grid.Column="1" Content="Search" Style="{StaticResource PrimaryButton}"
                        Height="36" Margin="8,0,0,0" Click="BtnSearch_Click"/>
            </Grid>

            <ListBox x:Name="LstProducts" Height="300" FontSize="13" SelectionChanged="LstProducts_SelectionChanged"/>

            <!-- Add Item Controls -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtSelectedProduct" Grid.Column="0" Text="No product selected"
                               VerticalAlignment="Center" Foreground="#607D8B" FontSize="13"/>
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="Qty" FontSize="11" Foreground="#607D8B"/>
                        <TextBox x:Name="TxtQty" Text="1" Height="32" FontSize="14" Padding="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="8,0">
                        <TextBlock Text="Discount ($)" FontSize="11" Foreground="#607D8B"/>
                        <TextBox x:Name="TxtItemDiscount" Text="0" Height="32" FontSize="14" Padding="4"/>
                    </StackPanel>
                    <Button Grid.Column="3" Content="Add to Cart" Style="{StaticResource PrimaryButton}"
                            Height="40" Margin="8,0,0,0" Click="BtnAddToCart_Click" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <!-- Cart -->
            <TextBlock Text="Cart" FontSize="16" FontWeight="Bold" Margin="0,16,0,8" Foreground="#37474F"/>
            <ListBox x:Name="LstCart" Height="180" FontSize="12" FontFamily="Consolas"/>
            <Button Content="Remove Selected" Style="{StaticResource DangerButton}" Margin="0,8,0,0"
                    Height="32" HorizontalAlignment="Left" Click="BtnRemoveItem_Click" FontSize="12"/>
        </StackPanel>

        <!-- Right Panel: Payment -->
        <Border Grid.Row="1" Grid.Column="1" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Text="Customer (Optional)" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtCustomerSearch" Grid.Column="0" Height="32" FontSize="13"
                             Padding="6,4"/>
                    <Button Grid.Column="1" Content="Find" Height="32" Margin="4,0,0,0"
                            Style="{StaticResource PrimaryButton}" FontSize="12" Padding="8,4"
                            Click="BtnFindCustomer_Click"/>
                </Grid>
                <ListBox x:Name="LstCustomers" Height="80" FontSize="12" Margin="0,0,0,12"
                         SelectionChanged="LstCustomers_SelectionChanged"/>
                <TextBlock x:Name="TxtSelectedCustomer" Text="No customer selected"
                           FontSize="12" Foreground="#607D8B" Margin="0,0,0,12"/>

                <Separator Margin="0,4,0,12"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <TextBlock Text="Subtotal:" FontSize="13" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtSubtotal" Text="$0.00" Grid.Column="1" HorizontalAlignment="Right" FontSize="13"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <TextBlock Text="Bill Discount ($):" FontSize="13"/>
                    <TextBox x:Name="TxtBillDiscount" Grid.Column="1" Text="0" Width="80"
                             HorizontalAlignment="Right" FontSize="13" Padding="4,2"
                             TextChanged="TxtBillDiscount_TextChanged"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <TextBlock Text="Points Redeem:" FontSize="13"/>
                    <TextBox x:Name="TxtPointsRedeem" Grid.Column="1" Text="0" Width="80"
                             HorizontalAlignment="Right" FontSize="13" Padding="4,2"
                             TextChanged="TxtPointsRedeem_TextChanged"/>
                </Grid>
                <Separator Margin="0,4,0,8"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <TextBlock Text="TOTAL:" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock x:Name="TxtTotal" Text="$0.00" Grid.Column="1"
                               HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                </Grid>

                <TextBlock Text="Payment Method" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
                <ComboBox x:Name="CboPayment" Height="32" FontSize="13" Margin="0,0,0,12">
                    <ComboBoxItem Content="Cash" IsSelected="True"/>
                    <ComboBoxItem Content="Card"/>
                    <ComboBoxItem Content="Credit"/>
                </ComboBox>

                <TextBlock Text="Amount Paid ($)" FontSize="12" Foreground="#607D8B" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtAmountPaid" Height="32" FontSize="14" Padding="6,4"
                         Margin="0,0,0,12" TextChanged="TxtAmountPaid_TextChanged"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <TextBlock Text="Change:" FontSize="14" FontWeight="Bold" Foreground="#2E7D32"/>
                    <TextBlock x:Name="TxtChange" Text="$0.00" Grid.Column="1"
                               HorizontalAlignment="Right" FontSize="14" FontWeight="Bold" Foreground="#2E7D32"/>
                </Grid>

                <Button Content="Complete Sale &amp; Print Bill" Style="{StaticResource PrimaryButton}"
                        Height="44" FontSize="15" Click="BtnCompleteSale_Click" Margin="0,0,0,8"/>
                <Button Content="🖨  Reprint Last Receipt" Height="36" FontSize="13"
                        Background="#37474F" Foreground="White" BorderThickness="0"
                        Padding="12,4" Cursor="Hand" Click="BtnReprint_Click" Margin="0,0,0,8"/>
                <Button Content="Clear Cart" Style="{StaticResource DangerButton}"
                        Height="36" FontSize="13" Click="BtnClearCart_Click"/>

                <TextBlock x:Name="TxtStatus" Text="" FontSize="12" Margin="0,12,0,0"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
