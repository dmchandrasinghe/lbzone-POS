<Window x:Class="LasanthaPOS.Desktop.Views.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product" Height="540" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        KeyboardNavigation.TabNavigation="Cycle">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Text="Add Product" FontSize="18" FontWeight="Bold"
                   Foreground="#1976D2" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" KeyboardNavigation.TabNavigation="Continue">
            <StackPanel>
                <TextBlock Text="Item Code *" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtItemCode" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"
                         TabIndex="1"/>

                <TextBlock Text="Product Name *" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtName" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"
                         TabIndex="2"/>

                <TextBlock Text="Category" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                <ComboBox x:Name="CboCategory" Height="32" Margin="0,0,0,10" FontSize="13"
                          TabIndex="3"/>

                <TextBlock Text="Supplier" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                <ComboBox x:Name="CboSupplier" Height="32" Margin="0,0,0,10" FontSize="13"
                          TabIndex="4"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Buying Price *" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                        <TextBox x:Name="TxtBuyingPrice" Height="32" Padding="6,4" FontSize="13"
                                 TabIndex="5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Selling Price *" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                        <TextBox x:Name="TxtSellingPrice" Height="32" Padding="6,4" FontSize="13"
                                 TabIndex="6"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Quantity *" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                        <TextBox x:Name="TxtQuantity" Height="32" Padding="6,4" FontSize="13"
                                 TabIndex="7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Reorder Threshold" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                        <TextBox x:Name="TxtReorder" Text="5" Height="32" Padding="6,4" FontSize="13"
                                 TabIndex="8"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Purchase Date" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                <DatePicker x:Name="DtPurchase" Height="32" Margin="0,0,0,10" FontSize="13"
                            TabIndex="9"/>

                <TextBlock Text="Expiration Date (optional)" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                <DatePicker x:Name="DtExpiration" Height="32" Margin="0,0,0,10" FontSize="13"
                            TabIndex="10"/>

                <TextBlock Text="Warranty (months, optional)" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtWarranty" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"
                         TabIndex="11"/>

                <TextBlock x:Name="TxtError" Foreground="Red" FontSize="12" Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Height="36" Padding="20,4" Margin="0,0,8,0"
                    BorderThickness="1" BorderBrush="#E0E0E0" Click="BtnCancel_Click"
                    TabIndex="12" IsCancel="True"/>
            <Button x:Name="BtnSave" Content="Save" Style="{StaticResource PrimaryButton}"
                    Height="36" Padding="20,4" Click="BtnSave_Click"
                    TabIndex="13" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
