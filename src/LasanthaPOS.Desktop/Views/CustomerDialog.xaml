<Window x:Class="LasanthaPOS.Desktop.Views.CustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Text="Add Customer" FontSize="18" FontWeight="Bold"
                   Foreground="#1976D2" Margin="0,0,0,16"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Full Name *" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtName" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"/>
            <TextBlock Text="Phone *" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtPhone" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"/>
            <TextBlock Text="Email" FontSize="12" Foreground="#607D8B" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtEmail" Height="32" Padding="6,4" Margin="0,0,0,10" FontSize="13"/>
            <TextBlock x:Name="TxtError" Foreground="Red" FontSize="12" Visibility="Collapsed"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Height="36" Padding="20,4" Margin="0,0,8,0"
                    BorderThickness="1" BorderBrush="#E0E0E0" Click="BtnCancel_Click"/>
            <Button Content="Save" Style="{StaticResource PrimaryButton}"
                    Height="36" Padding="20,4" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
