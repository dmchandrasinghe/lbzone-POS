<Window x:Class="LasanthaPOS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LasanthaPOS.Desktop"
        mc:Ignorable="d"
        Title="Lasantha Electronics POS" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <DockPanel Grid.Column="0" Background="#263238">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Lasantha POS" FontSize="16" FontWeight="Bold"
                           Foreground="#FF6F00" Padding="16,20" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtCurrentUser" Text="" FontSize="11"
                           Foreground="#78909C" Padding="16,0,16,16" TextWrapping="Wrap"/>
                <Separator Background="#37474F"/>

                <Button Content="🛒  Point of Sale" Style="{StaticResource NavButton}" Click="Nav_POS"/>
                <Button Content="📦  Inventory" Style="{StaticResource NavButton}" Click="Nav_Inventory"/>
                <Button Content="👥  Customers" Style="{StaticResource NavButton}" Click="Nav_Customers"/>
                <Button Content="🔒  Warranty" Style="{StaticResource NavButton}" Click="Nav_Warranty"/>
                <Button Content="📊  Daily Report" Style="{StaticResource NavButton}" Click="Nav_Report"/>
            </StackPanel>
            <Button DockPanel.Dock="Bottom" Content="⬅  Logout" Style="{StaticResource NavButton}"
                    Click="Nav_Logout" Margin="0,0,0,8" VerticalAlignment="Bottom"/>
        </DockPanel>

        <!-- Content Area -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>

